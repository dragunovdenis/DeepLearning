<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    DeepLearningOpenCpp - source injection.

    This file is auto-imported by NuGet in the consumer .vcxproj's
    <ImportGroup Label="ExtensionTargets"/> (i.e., AFTER Microsoft.Cpp.targets).
    All compile-time settings (include dirs, defines, language standard,
    conformance) are in the companion .props file so that they are visible
    BEFORE the C++ build pipeline computes its inputs.

    Only the <ClCompile> item injection lives here, gated on the public
    'DeepLearningCompileSources' property so consumers that link the library
    transitively (header-only consumers) can opt out and avoid duplicate
    symbols at link time.
  -->

  <!--
    Inject all shipped .cpp files into the consumer's compilation.
    PrecompiledHeader=NotUsing avoids collisions with the consumer's PCH setup.
  -->
  <ItemGroup Condition="'$(DeepLearningCompileSources)' == 'true'">
    <ClCompile Include="$(MSBuildThisFileDirectory)src\**\*.cpp">
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
    </ClCompile>
  </ItemGroup>
</Project>
